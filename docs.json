{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rekko AI",
  "colors": {
    "primary": "#00e87b",
    "light": "#00e87b",
    "dark": "#0C8C5E"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "grid",
    "color": {
      "dark": "#0a0a0a",
      "light": "#ffffff"
    }
  },
  "fonts": {
    "heading": {
      "family": "JetBrains Mono",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://rekko.ai"
  },
  "api": {
    "baseUrl": "https://api.rekko.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "openapi": ["/openapi.json"],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [

{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rekko AI",
  "colors": {
    "primary": "#00e87b",
    "light": "#00e87b",
    "dark": "#0C8C5E",
    "background": {
      "dark": "#0a0a0a"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "baseUrl": "https://api.rekko.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "openapi": ["/openapi.json"],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "pricing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Markets",
            "pages": [
              "api-reference/markets/list-markets",
              "api-reference/markets/get-market",
              "api-reference/markets/market-history"
            ]
          },
          {
            "group": "Insights",
            "pages": [
              "api-reference/insights/get-analysis",
              "api-reference/insights/list-analyses",
              "api-reference/insights/trigger-analysis",
              "api-reference/insights/poll-status",
              "api-reference/insights/screen-markets"
            ]
          },
          {
            "group": "Strategy",
            "pages": [
              "api-reference/strategy/generate-signal",
              "api-reference/strategy/portfolio-signal",
              "api-reference/strategy/execution-guidance"
            ]
          },
          {
            "group": "Deep Intelligence",
            "pages": [
              "api-reference/deep/arbitrage",
              "api-reference/deep/arbitrage-live",
              "api-reference/deep/correlation",
              "api-reference/deep/resolution"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "api-reference/analytics/calibration",
              "api-reference/analytics/sentiment",
              "api-reference/analytics/performance",
              "api-reference/analytics/performance-history"
            ]
          },
          {
            "group": "Streaming & Webhooks",
            "pages": [
              "api-reference/streaming/sse-stream",
              "api-reference/streaming/create-webhook",
              "api-reference/streaming/list-webhooks",
              "api-reference/streaming/delete-webhook"
            ]
          },
          {
            "group": "Consensus",
            "pages": [
              "api-reference/consensus/report-trade",
              "api-reference/consensus/get-consensus"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "api-reference/customers/signup",
              "api-reference/customers/me"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "MCP Server",
            "pages": [
              "integrations/mcp/overview",
              "integrations/mcp/claude-code",
              "integrations/mcp/cursor",
              "integrations/mcp/tools-reference"
            ]
          },
          {
            "group": "RapidAPI",
            "pages": [
              "integrations/rapidapi/overview"
            ]
          },
          {
            "group": "OpenClaw",
            "pages": [
              "integrations/openclaw/overview"
            ]
          },
          {
            "group": "Crypto Payments",
            "pages": [
              "integrations/x402/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://api.rekko.ai/health",
          "icon": "signal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://rekko.ai/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://rekko.ai/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor", "mcp"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/rekkoai",
      "github": "https://github.com/rekko-ai"
    }
  }
}
